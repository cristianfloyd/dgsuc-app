# Variables para ejecutar la app con Docker (docker compose)
# Copia las que necesites a tu .env o úsalas al levantar: docker compose --env-file .env up -d

# UID/GID del usuario del host (para que el contenedor tenga los mismos permisos)
# Ejecutar: echo "UID=$(id -u)" >> .env && echo "GID=$(id -g)" >> .env
UID=1000
GID=1000

# Base principal (contenedor PostgreSQL)
DB_DATABASE=suc_app
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Secundarias: misma base en el HOST (DB_TEST_*, DB_TEST_R2_*, DB_PROD_*, etc.)
DB_HOST_SECONDARY_PORT=5432
DB_HOST_SECONDARY_DATABASE=desa
DB_HOST_SECONDARY_USERNAME=postgres
DB_HOST_SECONDARY_PASSWORD=postgres

# Redis (opcional, el compose ya define REDIS_HOST=redis)
REDIS_PASSWORD=
